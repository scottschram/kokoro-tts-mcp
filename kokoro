#!/usr/bin/env bash
#
# kokoro — Text-to-speech using Kokoro-82M via mlx-audio
#
# Thin wrapper that invokes kokoro-cli.py with the project's venv Python.
# Playback supports pause/stop via sentinel files (/tmp/kokoro-tts-pause,
# /tmp/kokoro-tts-stop) — same mechanism used by the MCP server.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
VENV_PYTHON="${SCRIPT_DIR}/.venv/bin/python3.12"

[[ -x "${VENV_PYTHON}" ]] || {
    echo "kokoro: venv not found at ${VENV_PYTHON}. Run: python3.12 -m venv .venv && pip install -r requirements.txt" >&2
    exit 1
}

exec "${VENV_PYTHON}" "${SCRIPT_DIR}/kokoro-cli.py" "$@"
